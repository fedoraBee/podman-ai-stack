[Unit]
Description=Podman AI Stack Pod
BindsTo=podman-ai-stack-network.service
After=podman-ai-stack-network.service

[Pod]
Label=app=podman-ai-stack
PodName=podman-ai-stack
PublishPort=@BIND_IP@:@OPEN_WEBUI_PORT@:8080
PublishPort=@BIND_IP@:@OLLAMA_PORT@:11434
# Uses the Quadlet network configuration `podman-ai-stack.network`
Network=podman-ai-stack.network

[Service]
ExecStop=/usr/bin/podman pod stop podman-ai-stack
# Ensure the network is created before the pod starts
ExecStartPre=/usr/bin/podman network create --ignore --driver bridge --dns 1.1.1.1 --subnet 10.89.0.0/24 --gateway 10.89.0.1 --label app=podman-ai-stack podman-ai-stack
# Ensure the network is removed after the pod stops
ExecStopPost=/usr/bin/podman network rm --force podman-ai-stack